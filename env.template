# Configuração de Variáveis de Ambiente - Nossa Maternidade
#
# ⚠️ SEGURANÇA: Este arquivo contém APENAS placeholders
# NUNCA commite valores reais de API keys neste arquivo
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env: cp env.template .env (Windows: copy env.template .env)
# 2. Preencha os valores reais no arquivo .env (que está no .gitignore)
# 3. NUNCA commite o arquivo .env (ele está no .gitignore)

# ============================================
# VARIÁVEIS PÚBLICAS (EXPO_PUBLIC_*)
# ============================================
# Estas variáveis são seguras para serem incluídas no bundle do app
# Elas são acessadas via process.env.EXPO_PUBLIC_* no código
# ⚠️ ATENÇÃO: Mesmo sendo "públicas", não exponha chaves sensíveis desnecessariamente

# Supabase - URL do projeto
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase - Chave anônima (pública, segura para o app)
# Esta chave é projetada para ser pública e tem RLS (Row Level Security) habilitado
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase - URL das Edge Functions
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Google Gemini - API Key para IA
# ⚠️ NOTA: Esta chave é usada apenas em Edge Functions Supabase
# Para produção, configure como SECRET no Supabase: npx supabase secrets set GEMINI_API_KEY=xxx
# Esta variável aqui é apenas para desenvolvimento local/testes
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Gemini - Modelo padrão (usado pelas Edge Functions Supabase)
# Valores possíveis: gemini-2.5-flash (default), gemini-2.0-flash-exp, gemini-2.5-pro
# NOTA: Variável OPCIONAL - fallback para gemini-2.5-flash se não configurada
# Esta variável é APENAS para Edge Functions (Supabase), não para o app mobile
# GEMINI_MODEL=gemini-2.5-flash

# Claude API - API Key para IA (Anthropic)
EXPO_PUBLIC_CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI API - Recomendado para detecção de crise emocional
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Perplexity API - Para pesquisas e informações atualizadas
EXPO_PUBLIC_PERPLEXITY_API_KEY=your_perplexity_api_key_here

# MCP Brave Search - API Key (para MCP server local)
# NOTA: Esta variável NÃO tem EXPO_PUBLIC_ pois é apenas para servidor MCP local
# Se você estiver usando MCP servers localmente, configure aqui
BRAVE_API_KEY=your_brave_api_key_here

# Sentry - Error tracking (opcional, mas recomendado para produção)
# Crie uma conta em https://sentry.io e obtenha o DSN
# Formato: https://xxx@xxx.ingest.sentry.io/xxx
EXPO_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# Feature Flags (opcional)
EXPO_PUBLIC_ENABLE_AI_FEATURES=true
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_GAMIFICATION=false

# ============================================
# VARIÁVEIS PRIVADAS (NÃO USAR NO APP)
# ============================================
# Estas variáveis são apenas para referência
# NÃO devem ser usadas no código do app mobile
# Use apenas em backend/server-side (Edge Functions Supabase)
#
# ⚠️ IMPORTANTE: Estas variáveis NÃO devem estar no .env do app mobile
# Configure-as como SECRETS no Supabase para Edge Functions

# Supabase Service Role Key (NUNCA expor no cliente)
# Esta chave bypassa RLS - use APENAS em Edge Functions
# Configure como SECRET: npx supabase secrets set SUPABASE_SERVICE_ROLE_KEY=xxx
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Gemini API Key (para Edge Functions)
# Configure como SECRET no Supabase: npx supabase secrets set GEMINI_API_KEY=xxx
# NUNCA coloque esta chave no .env do app mobile
# GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (para Edge Functions - opcional)
# Configure como SECRET: npx supabase secrets set OPENAI_API_KEY=xxx
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API Key (para Edge Functions - opcional)
# Configure como SECRET: npx supabase secrets set ANTHROPIC_API_KEY=xxx
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL Connection String (apenas para migrações/admin local)
# Formato: postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# POSTGRES_CONNECTION_STRING=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# SEGURANÇA:
# - Todas as variáveis EXPO_PUBLIC_* são incluídas no bundle do app
# - Variáveis sem EXPO_PUBLIC_* não são acessíveis no app mobile
# - NUNCA commite o arquivo .env (apenas env.template com placeholders)
# - Para produção, use Supabase Secrets para chaves sensíveis em Edge Functions
#
# CONFIGURAÇÃO:
# - Para desenvolvimento local: copie env.template para .env e preencha os valores
# - Para Edge Functions: configure secrets no Supabase via CLI
#   Exemplo: npx supabase secrets set GEMINI_API_KEY=xxx
#
# DOCUMENTAÇÃO:
# - Para mais detalhes, veja: docs/setup-env.md
# - Supabase Secrets: https://supabase.com/docs/guides/functions/secrets
#
# TROUBLESHOOTING:
# - Se variáveis não estão sendo lidas, reinicie o servidor Expo: npx expo start -c
# - Verifique se o arquivo .env está na raiz do projeto
# - Verifique se as variáveis começam com EXPO_PUBLIC_ para serem acessíveis no app
