# .cursorignore - Reduz contexto e protege segredos

# Dependências, builds e caches
node_modules/
.git/
dist/
build/
coverage/
.expo/
.expo-shared/
.cache/
.next/
.turbo/

# Locks (quase nunca necessários para contexto)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Logs, temporários e SO
*.log
*.tmp
.DS_Store

# Segredos e env
.env
.env.*
.env.local

# Assets grandes
assets/screenshots/
assets/images/
assets/**/raw/
store-metadata/
public/assets/
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.mp4
*.mov
*.svg

# Documentação pesada
docs/archive/
*.pdf

# Supabase e ferramentas
supabase/.temp/
__tests__/coverage/
maestro/

# Configs que raramente precisam contexto
*.code-workspace
sentry.properties
cloudbuild.yaml
