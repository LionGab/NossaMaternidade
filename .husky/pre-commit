#!/bin/bash
# Pre-commit hook - Validação de Qualidade
# Compatível com Windows (Git Bash) e Unix

echo "🎨 Nossa Maternidade - Pre-commit Validation"
echo "============================================="

# 1. TypeScript Check (crítico - bloqueia commit)
echo ""
echo "📦 TypeScript..."
npm run type-check --silent
TS_RESULT=$?
if [ $TS_RESULT -ne 0 ]; then
  echo "❌ TypeScript falhou!"
  echo ""
  echo "🚫 COMMIT BLOQUEADO: Erros de TypeScript encontrados"
  echo "💡 Execute 'npm run type-check' para ver detalhes"
  exit 1
fi
echo "✅ TypeScript passou"

# 2. Validar sincronização do prompt NathIA (se arquivos relacionados foram modificados)
echo ""
echo "🤖 Validando prompt NathIA..."
if git diff --cached --name-only | grep -q "nathiaSystemPrompt.ts"; then
  npm run validate:nathia-prompt --silent
  if [ $? -ne 0 ]; then
    echo "⚠️  Prompt NathIA não está sincronizado!"
    echo "💡 Execute 'npm run sync:nathia-prompt' antes de commitar"
    echo "   (Commit não bloqueado, mas sincronize antes de fazer push)"
  else
    echo "✅ Prompt NathIA sincronizado"
  fi
else
  echo "⏭️  Nenhuma alteração no prompt NathIA"
fi

# 3. Lint-staged (arquivos modificados)
echo ""
echo "🧹 Executando lint nos arquivos staged..."
npx lint-staged --quiet
if [ $? -ne 0 ]; then
  echo ""
  echo "🚫 COMMIT BLOQUEADO: Erros de lint encontrados"
  echo "💡 Execute 'npm run lint' para ver detalhes"
  exit 1
fi

echo ""
echo "============================================="
echo "✅ Todas as validações passaram!"
echo "🚀 Commit autorizado - Nossa Maternidade"
echo "============================================="
exit 0
