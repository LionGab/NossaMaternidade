# ============================================
# NOSSA MATERNIDADE - Environment Variables
# ============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais!

# ============================================
# SUPABASE
# ============================================
EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://seu-projeto.supabase.co/functions/v1
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
# Project ID para gerar tipos TypeScript (npm run generate:types)
SUPABASE_PROJECT_ID=seu_project_id_aqui
# Conexao direta com PostgreSQL (usado pelo MCP postgres)
DATABASE_URL=postgresql://postgres:senha@db.seu-projeto.supabase.co:5432/postgres

# ============================================
# MCP SERVERS (Claude Code / Cursor)
# ============================================
# GitHub - para MCP server github (PRs, issues, code search)
GITHUB_TOKEN=ghp_seu_token_github_aqui

# AI APIs
EXPO_PUBLIC_GEMINI_API_KEY=sua_chave_gemini_aqui
EXPO_PUBLIC_CLAUDE_API_KEY=sua_chave_claude_aqui
EXPO_PUBLIC_OPENAI_API_KEY=sua_chave_openai_aqui
EXPO_PUBLIC_PERPLEXITY_API_KEY=sua_chave_perplexity_aqui

# Brave Search
BRAVE_API_KEY=sua_chave_brave_aqui

# Sentry (opcional)
EXPO_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ElevenLabs - Text-to-Speech (Voz personalizada)
EXPO_PUBLIC_ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui

# OneSignal (opcional)
EXPO_PUBLIC_ONESIGNAL_APP_ID=seu_app_id_onesignal

# Social Login (OAuth)
# true = habilita login com Google/Apple (requer configuração no Supabase)
# false = desabilita botões de login social
EXPO_PUBLIC_SOCIAL_LOGIN_ENABLED=true
