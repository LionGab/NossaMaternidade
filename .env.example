# =============================================================================
# CLOUD RUN BACKEND (AI Orchestrator)
# =============================================================================
# URL do backend em Cloud Run que processa as chamadas de IA
# Desenvolvimento local (iOS/Web): http://localhost:8080
# Desenvolvimento local (Android): http://10.0.2.2:8080
# Produção: https://your-cloud-run-url.run.app
EXPO_PUBLIC_BACKEND_URL=https://copy-of-nossa-maternidade0555-854690283424.us-west1.run.app

# =============================================================================
# SUPABASE
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Supabase Service Role Key (PRIVADA - para MCPs/backend)
# Obtenha em: Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# GEMINI AI
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
# Recomendado: deixar vazio e usar apenas via Cloud Run backend
EXPO_PUBLIC_GEMINI_API_KEY=your_api_key_here

# =============================================================================
# GITHUB MCP
# =============================================================================
# GitHub Personal Access Token (para GitHub MCP)
# Get it from: https://github.com/settings/tokens
# Scopes needed: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# =============================================================================
# FEATURE FLAGS
# =============================================================================
EXPO_PUBLIC_ENABLE_AI_FEATURES=true
EXPO_PUBLIC_ENABLE_GAMIFICATION=true
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# =============================================================================
# OPTIONAL SERVICES (Futuro)
# =============================================================================
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_ONESIGNAL_APP_ID=
EXPO_PUBLIC_SENTRY_DSN=

# =============================================================================
# EAS & BUILD
# =============================================================================
EAS_PROJECT_ID=
APP_ENV=development
