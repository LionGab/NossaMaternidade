{
  "name": "nossa-maternidade-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "expo": {
    "install": {
      "exclude": [
        "jest",
        "@types/jest",
        "@sentry/react-native"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --port 8082",
    "build": "npm run build:android",
    "build:web": "expo export:web",
    "build:dev": "eas build --platform all --profile development",
    "build:preview": "eas build --platform all --profile preview",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "build:production": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:all": "eas submit --platform all --profile production",
    "update": "eas update --branch production --message",
    "prebuild": "expo prebuild --clean",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "validate:android": "node scripts/validate-android.js",
    "prepare:assets": "node scripts/prepare-assets.js",
    "prebuild:android": "npm run validate:android",
    "check-ready": "pwsh -File scripts/check-ready.ps1",
    "check-ready:bash": "bash scripts/check-ready.sh",
    "validate:env": "node scripts/validate-env.js",
    "test:connection": "node scripts/test-connection.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@expo/vector-icons": "^15.0.3",
    "@google/generative-ai": "^0.24.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.8.6",
    "@react-navigation/native": "^7.1.21",
    "@react-navigation/native-stack": "^7.6.4",
    "@sentry/react-native": "^7.7.0",
    "@shopify/flash-list": "^2.0.2",
    "@supabase/supabase-js": "^2.84.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.25",
    "expo-blur": "^15.0.7",
    "expo-constants": "^18.0.10",
    "expo-dev-client": "^6.0.18",
    "expo-file-system": "^19.0.19",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "^15.0.7",
    "expo-linking": "~8.0.9",
    "expo-localization": "~17.0.7",
    "expo-secure-store": "~15.0.7",
    "expo-speech": "^14.0.7",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-tracking-transparency": "~6.0.7",
    "lucide-react-native": "^0.554.0",
    "nativewind": "^4.2.1",
    "openai": "^6.9.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-constant-elements": "^7.27.1",
    "@babel/plugin-transform-react-inline-elements": "^7.27.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-preset-expo": "^54.0.7",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "jest": "^30.2.0",
    "jest-expo": "^54.0.13",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.4.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
